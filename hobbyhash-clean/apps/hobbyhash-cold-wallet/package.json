{
  "name": "hobbyhash-cold-wallet",
  "version": "0.1.0-beta",
  "description": "Offline, non-custodial cold storage wallet for HobbyHash Coin (HOBC).",
  "productName": "HobbyHash Cold Wallet",
  "main": "src/main.js",
  "author": "HobbyHash Coin",
  "license": "MIT",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dist:win": "electron-builder --win portable nsis --x64",
    "dist:portable": "electron-builder --win portable --x64"
  },
  "dependencies": {
    "bip32": "^5.0.0",
    "bip39": "^3.1.0",
    "bitcoinjs-lib": "^7.0.0",
    "qrcode": "^1.5.4",
    "tiny-secp256k1": "^2.2.4"
  },
  "devDependencies": {
    "electron": "^39.2.7",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.hobbyhashcoin.coldwallet",
    "productName": "HobbyHash Cold Wallet",
    "copyright": "Copyright 2026 HobbyHash Coin",
    "directories": {
      "output": "dist/windows"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "asar": true,
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "HobbyHash-Cold-Wallet-${target}.${ext}"
    },
    "portable": {
      "artifactName": "HobbyHash-Cold-Wallet-Portable.exe"
    },
    "nsis": {
      "artifactName": "HobbyHash-Cold-Wallet-Setup.exe",
      "oneClick": false,
      "perMachine": false,
      "allowElevation": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "HobbyHash Cold Wallet"
    }
  }
}
