# Copy to .env and fill in locally. Never commit .env.
GOOGLE_CLOUD_PROJECT_ID=
GOOGLE_CLOUD_API_KEY=
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
GOOGLE_TRANSLATE_LOCATION=global

# Path to private wallet config (outside public_html)
HOBC_WALLET_CONFIG=/home/hobbyhashcoin/hobbyhash-wallet-private/config.php

# Admin + analytics display timezone (Pacific)
HOBC_ADMIN_TIMEZONE=America/Los_Angeles
HOBC_ANALYTICS_TIMEZONE=America/Los_Angeles
