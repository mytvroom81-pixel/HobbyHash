Options -Indexes

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Never rewrite admin, API, jobs, app code, assets, vendor, or catalog files.
    RewriteRule ^(?:admin|api|jobs|app|assets|vendor|lang|config|includes)(?:/|$) - [L,NC]

    # Wallet authenticated/action endpoints stay on unprefixed URLs.
    RewriteRule ^(?:es|fr|de|it|pt-br|nl|pl|ru|uk|tr|ar|he|hi|bn|ur|id|ms|vi|th|ja|ko|zh-cn|zh-tw|tl|sw)/wallet/(?!index\.php$)(.+)$ /wallet/$1 [L,R=301,NC]

    # Locale home page.
    RewriteRule ^(es|fr|de|it|pt-br|nl|pl|ru|uk|tr|ar|he|hi|bn|ur|id|ms|vi|th|ja|ko|zh-cn|zh-tw|tl|sw)/?$ index.php [L,QSA,E=HOBC_PATH_LOCALE:$1]

    # Add trailing slash for locale-prefixed directory paths (not static files).
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_URI} !\.[a-z0-9]{1,8}$ [NC]
    RewriteRule ^(es|fr|de|it|pt-br|nl|pl|ru|uk|tr|ar|he|hi|bn|ur|id|ms|vi|th|ja|ko|zh-cn|zh-tw|tl|sw)/(.+[^/])$ /$1/$2/ [L,R=301]

    # Locale-prefixed public pages map to existing English slugs.
    RewriteRule ^(es|fr|de|it|pt-br|nl|pl|ru|uk|tr|ar|he|hi|bn|ur|id|ms|vi|th|ja|ko|zh-cn|zh-tw|tl|sw)/(.+)$ /$2 [L,QSA,E=HOBC_PATH_LOCALE:$1]
</IfModule>
