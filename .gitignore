# HOBC node source only — builds hobbyhashd, hobbyhash-cli, hobbyhash-tx,
# hobbyhash-util, hobbyhash-wallet locally. No website, wallets apps, or pools.

/*
!/.gitignore
!/README.md
!/hobbyhash-clean/
!/hobbyhash-clean/src/
!/hobbyhash-clean/src/**

# Never commit secrets
**/.env
**/config.php
**/*credentials*.json
**/*.pem
**/*.key

# Compiled binaries — build on each machine, never commit
**/hobbyhashd
**/hobbyhash-cli
**/hobbyhash-tx
**/hobbyhash-util
**/hobbyhash-wallet
**/bitcoind
**/bitcoin-cli
**/bitcoin-tx
**/bitcoin-util
**/bitcoin-wallet

# Build outputs
**/node_modules/
**/release-*/
**/autom4te.cache/
**/.deps/
**/.libs/
**/__pycache__/
**/logs/
**/*.log
**/*.o
**/*.a
**/*.lo
**/*.la
**/*.exe
**/*.tar.gz
**/*.zip
**/dist/
**/build/
!**/build_msvc/
!**/build-aux/

**/.git/
