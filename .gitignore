# HobbyHash Coin — node, wallet, and pool source only
# Web portal (public_html) and social-bot stay on the server.

/*
!/.gitignore
!/README.md
!/scripts/
!/scripts/**
!/hobbyhash-clean/
!/hobbyhash-clean/**

# Never commit secrets or live config
**/.env
!**/.env.example
**/config.php
!**/config.example.php
**/*credentials*.json
**/*service-account*.json
**/*.pem
**/*.key
**/internal-token

# Build outputs and runtime data
**/node_modules/
**/release-*/
**/autom4te.cache/
**/.deps/
**/.libs/
**/__pycache__/
**/logs/
**/*.log
**/*.o
**/*.a
**/*.lo
**/*.la
**/*.db
**/*.db-shm
**/*.db-wal
**/*.exe
**/*.tar.gz
**/*.zip
**/*.7z
**/dist/
**/build/
!**/build_msvc/
!**/build-aux/

# Windows builds (Linux-focused repo)
/hobbyhash-clean/WIN/

# Nested repos — contents tracked in this monorepo instead
**/.git/
