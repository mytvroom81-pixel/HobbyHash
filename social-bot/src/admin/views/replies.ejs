<%- include('partials/head', { title: 'Replies' }) %>
<%- include('partials/nav') %>
<main>
  <h2>Reply history</h2>
  <% replies.forEach(r => { %>
  <div class="card">
    <span class="badge badge-<%= r.status %>"><%= r.status %></span>
    <strong><%= r.platform %></strong> — intent: <%= r.intent %> (<%= (r.confidence * 100).toFixed(0) %>%)
    <p><strong>In:</strong> <%= r.incoming_text %></p>
    <p><strong>Reply:</strong> <%= r.reply_text %></p>
    <% if (r.status === 'pending') { %>
    <form class="inline" method="POST" action="/admin/replies/<%= r.id %>/approve">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <button class="btn btn-primary">Approve send</button>
    </form>
    <form class="inline" method="POST" action="/admin/replies/<%= r.id %>/reject">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <button class="btn btn-danger">Reject</button>
    </form>
    <% } %>
  </div>
  <% }) %>
</main>
<%- include('partials/foot') %>
