<%- include('partials/head', { title: 'Preview' }) %>
<%- include('partials/nav') %>
<main>
  <h2>Preview generated post</h2>
  <div class="card">
    <form method="GET" action="/admin/preview">
      <input type="hidden" name="generate" value="1">
      <label>Platform</label>
      <select name="platform"><% platforms.forEach(p => { %><option value="<%= p %>"><%= p %></option><% }) %></select>
      <label>Topic (optional)</label>
      <input type="text" name="topic" placeholder="e.g. pool_status">
      <button type="submit" class="btn btn-primary">Generate preview</button>
    </form>
  </div>
  <% if (error) { %><p class="error"><%= error %></p><% } %>
  <% if (preview) { %>
  <div class="card">
    <p><strong>Topic:</strong> <%= preview.topic %> | <strong>Tone:</strong> <%= preview.tone %> | <strong>Template:</strong> <%= preview.templateName %></p>
    <div class="content-preview"><%= preview.content %></div>
  </div>
  <% } %>
</main>
<%- include('partials/foot') %>
