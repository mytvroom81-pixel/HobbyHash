<%- include('partials/head', { title: 'Platforms' }) %>
<%- include('partials/nav') %>
<main>
  <h2>Platforms</h2>
  <p style="color:var(--muted)">Toggle platforms here. API keys are set via <code>.env</code> only — never stored in the database.</p>
  <% accounts.forEach(account => { %>
  <div class="card">
    <h3><%= account.platform.toUpperCase() %></h3>
    <form method="POST" action="/admin/platforms/<%= account.platform %>">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <label>
        <input type="checkbox" name="enabled" value="1" <%= account.enabled ? 'checked' : '' %>>
        Enabled
      </label>
      <button type="submit" class="btn btn-primary">Save</button>
    </form>
  </div>
  <% }) %>
  <div class="card">
    <h3>Environment variables</h3>
    <% envInstructions.forEach(group => { %>
      <h4><%= group.platform %></h4>
      <ul><% group.vars.forEach(v => { %><li><span class="env-var"><%= v %></span></li><% }) %></ul>
    <% }) %>
    <p>Edit <code>/social-bot/.env</code> then restart the service: <code>sudo systemctl restart hobbyhash-social-bot</code></p>
  </div>
</main>
<%- include('partials/foot') %>
