<%- include('partials/head', { title: 'Audit Log' }) %>
<%- include('partials/nav') %>
<main>
  <h2>Audit log</h2>
  <table>
    <thead><tr><th>Time</th><th>Action</th><th>Actor</th><th>Details</th></tr></thead>
    <tbody>
    <% logs.forEach(l => { %>
      <tr>
        <td><%= l.created_at %></td>
        <td><%= l.action %></td>
        <td><%= l.actor %></td>
        <td><%= l.details %></td>
      </tr>
    <% }) %>
    </tbody>
  </table>
</main>
<%- include('partials/foot') %>
