<%- include('partials/head', { title: 'History' }) %>
<%- include('partials/nav') %>
<main>
  <h2>Post history</h2>
  <table>
    <thead><tr><th>Time</th><th>Platform</th><th>Status</th><th>Topic</th><th>Content</th></tr></thead>
    <tbody>
    <% posts.forEach(p => { %>
      <tr>
        <td><%= p.published_at || p.created_at %></td>
        <td><%= p.platform %></td>
        <td><span class="badge badge-<%= p.status %>"><%= p.status %></span></td>
        <td><%= p.topic %></td>
        <td><%= p.content.slice(0, 120) %><%= p.content.length > 120 ? '…' : '' %></td>
      </tr>
    <% }) %>
    </tbody>
  </table>
</main>
<%- include('partials/foot') %>
