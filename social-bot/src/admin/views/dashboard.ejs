<%- include('partials/head', { title: 'Dashboard' }) %>
<%- include('partials/nav') %>
<main>
  <h2>Dashboard</h2>
  <div class="grid">
    <div class="card stat"><div class="num"><%= stats.pendingPosts %></div><div class="label">Pending posts</div></div>
    <div class="card stat"><div class="num"><%= stats.publishedToday %></div><div class="label">Published today</div></div>
    <div class="card stat"><div class="num"><%= stats.pendingReplies %></div><div class="label">Pending replies</div></div>
    <div class="card stat"><div class="num"><%= stats.unprocessedEvents %></div><div class="label">Unprocessed events</div></div>
  </div>
  <div class="card">
    <h3>Enabled platforms</h3>
    <% if (stats.platforms.length === 0) { %>
      <p>No platforms enabled. <a href="/admin/platforms">Configure platforms</a></p>
    <% } else { %>
      <ul><% stats.platforms.forEach(p => { %><li><%= p.platform %> — <%= p.display_name || p.platform %></li><% }) %></ul>
    <% } %>
  </div>
  <div class="card">
    <form method="POST" action="/admin/run-scheduler">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <button type="submit" class="btn btn-secondary">Run scheduler tick now</button>
    </form>
  </div>
</main>
<%- include('partials/foot') %>
