<%- include('partials/head', { title: 'Templates' }) %>
<%- include('partials/nav') %>
<main>
  <h2>Post templates</h2>
  <% templates.forEach(t => { %>
  <div class="card">
    <form method="POST" action="/admin/templates/<%= t.id %>">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <strong><%= t.name %></strong> — tone: <%= t.tone %>, topic: <%= t.topic %>
      <label>Body (placeholders: {height}, {miners}, {hashrate}, etc.)</label>
      <textarea name="template_body" rows="3"><%= t.template_body %></textarea>
      <label>Weight</label>
      <input type="number" name="weight" value="<%= t.weight %>" min="1" max="10">
      <label><input type="checkbox" name="enabled" value="1" <%= t.enabled ? 'checked' : '' %>> Enabled</label>
      <button type="submit" class="btn btn-primary">Update</button>
    </form>
  </div>
  <% }) %>
  <div class="card">
    <h3>Add template</h3>
    <form method="POST" action="/admin/templates">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <label>Name</label><input type="text" name="name" required>
      <label>Tone</label><input type="text" name="tone" required placeholder="casual_miner">
      <label>Topic</label><input type="text" name="topic" required placeholder="pool_status">
      <label>Body</label><textarea name="template_body" rows="3" required></textarea>
      <label>Weight</label><input type="number" name="weight" value="1">
      <button type="submit" class="btn btn-primary">Create</button>
    </form>
  </div>
</main>
<%- include('partials/foot') %>
