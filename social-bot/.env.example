# ── Server ──────────────────────────────────────────────────────────────────
PORT=3847
NODE_ENV=production
SESSION_SECRET=change-me-to-a-long-random-string
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-strong-password
# Or use a bcrypt hash instead of plain password:
# ADMIN_PASSWORD_HASH=$2a$12$...

# ── Site URLs ───────────────────────────────────────────────────────────────
SITE_URL=https://hobbyhashcoin.com
DOCS_URL=https://hobbyhashcoin.com/docs/
POOL_URL=https://hobbyhashcoin.com/pool/
EXPLORER_URL=https://hobbyhashcoin.com/explorer/
WALLET_URL=https://hobbyhashcoin.com/wallet/
DOWNLOADS_URL=https://hobbyhashcoin.com/downloads/
SUPPORT_URL=https://hobbyhashcoin.com/support/

# ── Data sources ────────────────────────────────────────────────────────────
# Public API base (no trailing slash)
HOBC_API_BASE=https://hobbyhashcoin.com/api
# Pool stats JSON files (local paths on server)
POOL_STATS_MAIN=/home/hobbyhashcoin/hobbyhash-data/mainnet/pool-stats-main.json
POOL_STATS_NANO=/home/hobbyhashcoin/hobbyhash-data/mainnet/pool-stats-nano.json
# Optional MySQL read-only access for site stats / downloads
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=hobbyhash_wallet
# Optional hobbyhash-cli for chain data
HOBBYHASH_CLI=/usr/local/bin/hobbyhash-cli
HOBBYHASH_CLI_CONF=/home/hobbyhashcoin/hobbyhash-conf/hobbyhash.conf

# ── Discord ─────────────────────────────────────────────────────────────────
DISCORD_ENABLED=false
# Bot token OR webhook URL (webhook is simpler for posting only)
DISCORD_BOT_TOKEN=
DISCORD_WEBHOOK_URL=
DISCORD_CHANNEL_ID=
# Comma-separated channel IDs where FAQ replies are allowed
DISCORD_REPLY_CHANNEL_IDS=

# ── X (Twitter) ─────────────────────────────────────────────────────────────
X_ENABLED=false
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=
X_BEARER_TOKEN=
# Set true to allow replying to mentions (requires elevated API access)
X_REPLY_ENABLED=false

# ── Facebook Page ───────────────────────────────────────────────────────────
FACEBOOK_ENABLED=false
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=
FACEBOOK_REPLY_ENABLED=false

# ── OpenAI-compatible text generation (optional) ────────────────────────────
AI_ENABLED=false
AI_API_KEY=
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini

# ── Integration with HOBC PHP admin ───────────────────────────────────────────
# Set here OR store token in data/internal-token (auto-generated, gitignored)
SOCIAL_BOT_INTERNAL_TOKEN=
# Disable the standalone Node admin panel when using /admin/social-bot.php
SOCIAL_BOT_STANDALONE_ADMIN=false
# Dry-run: generate posts but do not publish (default ON — disable when go-live)
DRY_RUN=1

# Admin display timezone for social bot schedules/budgets (optional; matches Site Analytics if unset)
# HOBC_ADMIN_TIMEZONE=America/Los_Angeles

# ── SQLite database path ────────────────────────────────────────────────────
DB_PATH=./data/social-bot.db
